@startuml LLMProviders
title <b>NextGenChat — LLM Provider Layer</b>\n<size:11>Five providers · credential encryption · token counting · prompt caching</size>
left to right direction
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam defaultFontName Helvetica

package "Provider Registry" #E8F0FF {
  [ProviderRegistry\n(instantiate + cache by config hash)] as Reg
  note bottom of Reg
    Resolves provider for an agent based on ProviderConfig.
    Caches live instances keyed by hash(providerName + model + key).
    All credentials decrypted via CryptoService (AES-256-GCM).
  end note
}

package "Implemented Providers" #F0FFF4 {

  package "OpenAI Provider" #FAFFFE {
    [openai.provider.ts\nModel: gpt-4o · gpt-4o-mini · etc.\nToken counting: tiktoken\nStreaming: real provider.stream()] as OAI
  }

  package "Anthropic Provider" #FAFFFE {
    [anthropic.provider.ts\nModel: claude-opus-4-6 · claude-sonnet-4-6\nclaude-haiku-4-5 · etc.\nToken counting: /v1/messages/count_tokens\nPrompt caching: cache_control ephemeral\nTracks cache_read vs cache_creation tokens] as ANT
  }

  package "Kimi Provider" #FAFFFE {
    [kimi.provider.ts\nExtends: OpenAI provider\nBase URL: api.moonshot.cn\nModel: moonshot-v1-*\nAuth: API key (same flow as OpenAI)] as KIMI
  }

  package "OpenRouter Provider" #FAFFFE {
    [openrouter.provider.ts\nExtends: OpenAI-compatible\nModel list: fetched from OpenRouter + cached in Redis\nSupports: hundreds of hosted models\nAuth: OpenRouter API key] as OR
  }

  package "OpenAI Codex OAuth" #FAFFFE {
    [openai-codex-oauth.provider.ts\nAuth: OAuth 2.0 flow\nTokens stored in: OAuthToken table (encrypted)\nAuto-refresh: before each request if expired\nModel: code-specific Codex endpoints] as CODEX
  }
}

package "Shared Interface (LLMProvider)" #FFF8E0 {
  component "LLMProvider Interface\n(@nextgenchat/types)\n─────────────────────────────\nstream(messages, tools): AsyncIterable<delta>\ncomplete(messages, tools): Promise<response>\ncountTokens(messages): Promise<number>\ngetModelLimit(): number\n─────────────────────────────\nAgentSessionGateway calls only this interface.\nNever imports a concrete provider directly." as LLMProvider
}

package "External APIs" #FFF0F0 {
  cloud "api.openai.com" as OpenAICloud
  cloud "api.anthropic.com" as AnthropicCloud
  cloud "api.moonshot.cn" as KimiCloud
  cloud "openrouter.ai/api" as ORCloud
  cloud "api.openai.com\n(Codex OAuth)" as CodexCloud
}

package "Token Counting Strategy" #F5F5FF {
  note as TCNote
    OpenAI / Kimi / OpenRouter:
    · tiktoken (local, fast, exact for GPT-family models)

    Anthropic:
    · POST /v1/messages/count_tokens (exact, API call)
    · Adds cache_control: { type: "ephemeral" } after static prefix
    · cache_read_input_tokens tracked in message.metadata
    · cache_creation_input_tokens tracked in message.metadata

    All providers:
    · Always reserve RESPONSE_BUFFER = 4096 tokens
    · budget = modelLimit − responseBuffer
  end note
}

