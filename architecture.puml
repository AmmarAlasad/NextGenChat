@startuml MessagePipeline
title <b>NextGenChat — Agent Message Pipeline</b>\n<size:10>Current runtime path from user message to streamed reply</size>

actor User
participant "Web UI" as Web
participant "Socket.io /chat" as SIO
participant "Chat service" as ChatSvc
database "SQLite" as DB
participant "Agents service" as AgentSvc
queue "Local job dispatch" as Queue
participant "Agent processor" as Worker
participant "Context builder" as CB
participant "Workspace service" as WS
participant "OpenAI provider" as OAI

User -> Web : send message
Web -> SIO : message:send
SIO -> ChatSvc : validate + persist
ChatSvc -> DB : insert user message
ChatSvc -> SIO : emit message:new
SIO -> AgentSvc : resolve triggered agents
AgentSvc -> Queue : queue agent run
Queue -> Worker : process(agent, channel, message)

Worker -> CB : build context
CB -> WS : ensure agent docs exist
CB -> DB : load memory, summary, recent messages
CB -> CB : enforce token budget
CB -> Queue : schedule compaction if needed
CB --> Worker : final prompt payload

Worker -> OAI : stream(messages)
loop streaming chunks
  OAI --> Worker : delta
  Worker -> SIO : message:stream:chunk
  SIO --> Web : render live response
end

OAI --> Worker : final usage
Worker -> DB : insert agent message + metadata
Worker -> SIO : message:stream:end
Worker -> SIO : message:new

note right of CB
  Build order today:
  1. identity.md / agency.md / agent.md / heartbeat.md
  2. structured memory
  3. latest conversation summary
  4. recent fitting messages
  5. trigger message last
end note

@enduml


@startuml ContextModel
title <b>NextGenChat — Context Model</b>\n<size:10>How prompt assembly, compaction, and cache-sensitive structure work today</size>
start

:Resolve provider + model limit;
:Reserve response buffer;
:Ensure agent docs exist;
:Load identity.md, agency.md, agent.md, heartbeat.md;
:Load structured agent memory;
:Load latest conversation summary;
:Load recent channel messages;
:Load trigger message;
:Assemble stable prefix first;
:Estimate tokens;

if (Within budget?) then (yes)
  :Use fitting recent window;
else (no)
  :Drop oldest turns until fit;
  :Schedule async compaction for overflow;
endif

:Compute static prefix hash;
:Send prompt to provider;
:Persist usage metadata with agent message;
stop

note right
  Current important behavior:
  compaction is scheduled before hard overflow,
  but it does not block the current reply.

  Memory survives compaction because it is stored
  outside the raw transcript and reloaded each run.
end note

@enduml


@startuml DomainModel
title <b>NextGenChat — Current Domain Model</b>\n<size:10>Core persisted entities in the running app</size>
start

partition "Identity and access" {
  :User\nusername, passwordHash;
  :Workspace\nname, slug;
}

partition "Conversation model" {
  :Channel\nworkspaceId, name, type;
  :Message\nchannelId, senderType, content, metadata;
  :ConversationSummary\nchannelId, agentId, summary, tokenCount;
}

partition "Agent model" {
  :Agent\nworkspaceId, name, slug, triggerMode, primaryChannelId;
  :AgentIdentity\npersona, voiceTone, systemPrompt;
  :AgentMemory\nscope, key, value;
  :ProviderConfig\nproviderName, model, encrypted credentials;
}

partition "Agent workspace docs" {
  :WorkspaceFile\ndocType, fileName, content, version;
  :Current docs = agent.md, identity.md, agency.md, heartbeat.md, memory.md;
}

partition "Relationship summary" {
  :Workspace contains channels and agents;
  :Channels store messages;
  :Agents own identity, memory, summaries, docs, and provider config;
  :memory.md is the readable projection of AgentMemory;
}

stop
@enduml
