@startuml SystemOverview
title <b>NextGenChat — System Overview</b>\n<size:10>Current local-first runtime and major subsystems</size>
start

partition "Operator" {
  :Owner / admin uses browser UI;
}

partition "Frontend" {
  :Setup and login flow;
  :Chat interface;
  :Agent workspace editor;
}

partition "Backend" {
  :Fastify API;
  :Socket.io /chat;
  :Auth service;
  :Chat service;
  :Agents service;
  :Workspace service;
  :Agent processor (local in-process job);
  :Context builder;
  :Compaction service;
  :OpenAI provider;
}

partition "Storage" {
  :SQLite database;
  :Agent workspace docs via WorkspaceFile rows;
}

partition "External" {
  :OpenAI API;
}

partition "Current product scope" {
  :One local owner;
  :One seeded workspace;
  :One seeded channel;
  :One seeded agent;
}

partition "Planned later" {
  :Group chats;
  :Shared workspaces;
  :Repo and file tools;
  :Heartbeat execution loop;
}

stop
@enduml


