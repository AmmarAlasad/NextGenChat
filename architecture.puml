title <b>NextGenChat — LLM Provider Layer</b>\n<size:10>packages/types/src/providers.ts  +  apps/backend/src/modules/providers/</size>

' ── Shared Types (packages/types) ──────────────────────────────

class "LLMMessage" as TMsg {
  + role: 'system' | 'user' | 'assistant' | 'tool'
  + content: string | ContentPart[]
  + toolCallId?: string
  + name?: string
  + cache_control?: CacheControl
}

class "LLMRequestOptions" as TOpts {
  + messages: LLMMessage[]
  + tools?: LLMTool[]
  + maxTokens?: number
  + temperature?: number
  + stream?: boolean
  + systemPrompt?: string
}

class "LLMResponse" as TResp {
  + id: string
  + content: string
  + finishReason: FinishReason
  + toolCalls?: ToolCall[]
  + usage: TokenUsage
  + providerMetadata?: Record<string, unknown>
}

note right of TResp
  <b>TokenUsage contains:</b>
  promptTokens, completionTokens,
  totalTokens, cachedTokens?
  Stored in Message.metadata JSONB.
  Used for cost analytics per agent.
end note

class "LLMStreamChunk" as TChunk {
  + delta: string
  + finishReason?: FinishReason
  + toolCallDelta?: ToolCallDelta
}

class "TokenUsage" as TUsage {
  + promptTokens: number
  + completionTokens: number
  + totalTokens: number
  + cachedTokens?: number
}

TResp *-- TUsage

' ── Interface (packages/types) ─────────────────────────────────

interface "<<interface>>\nLLMProvider" as IProvider {
  + name: ProviderName
  + supportedModels: string[]
  + contextLimits: Map<string, number>
  ..
  + complete(opts: LLMRequestOptions): Promise<LLMResponse>
  + stream(opts: LLMRequestOptions): AsyncGenerator<LLMStreamChunk>
  + countTokens(messages: LLMMessage[]): Promise<number>
}

note top of IProvider
  <b>Defined in packages/types — shared across all apps.</b>
  Callers always use this interface, never concrete classes.
  ProviderRegistry returns IProvider.
  Zod schema validates all request/response shapes at runtime.
end note

' ── Base Implementation ─────────────────────────────────────────

abstract class "BaseProvider" as Base {
  # name: ProviderName
  # baseURL: string
  # apiKey: string
  # httpClient: AxiosInstance
  ..
  + complete(opts): Promise<LLMResponse>
  + stream(opts): AsyncGenerator<LLMStreamChunk>
  # buildHeaders(): Record<string, string>
  # mapError(err: HttpError): LLMError
  # parseSSEChunk(raw: string): LLMStreamChunk | null
}

note right of Base
  <b>Shared error mapping (all providers):</b>
  HTTP 429 → RATE_LIMITED
    retry max 3x, exponential backoff
  HTTP 401 → AUTH_FAILED
    no retry, alert admin in channel
  HTTP 500/503 → PROVIDER_ERROR
    retry max 3x, exponential backoff
  Job timeout (90s) → LLM_TIMEOUT
    no retry, emit error to channel
end note

' ── Concrete Providers ──────────────────────────────────────────

class "OpenAIProvider" as POai {
  + name = 'openai'
  + baseURL = 'https://api.openai.com/v1'
  + supportedModels = ['gpt-4o', 'gpt-4o-mini',\n'gpt-4-turbo', 'o1', 'o3', 'o3-mini']
  + contextLimits = { 'gpt-4o': 128000, 'o1': 200000, ... }
  - encoding: Tiktoken
  ..
  + countTokens(messages): Promise<number>
  - buildFunctionDefs(tools): OpenAIFunction[]
}

note bottom of POai
  <b>Token counting:</b> tiktoken cl100k_base
  +4 tokens per message for role overhead.
  <b>Tool calling:</b> OpenAI function calling format.
  <b>Streaming:</b> SSE "data: {...}" prefix,
  parse content_delta from each event.
end note

class "OpenAICodexOAuthProvider" as POauthCodex {
  - oauthAccessToken: string
  - refreshToken: string
  - tokenExpiresAt: Date
  - agentId: string
  ..
  + complete(opts): Promise<LLMResponse>
  + stream(opts): AsyncGenerator<LLMStreamChunk>
  - ensureTokenFresh(): Promise<void>
  + handleCallback(code, state): Promise<void>
}

note bottom of POauthCodex
  <b>OAuth 2.0 Authorization Code flow:</b>
  1. Admin clicks Connect → backend generates auth URL + state
  2. User consents on OpenAI OAuth page
  3. Callback: backend exchanges code → access + refresh tokens
  4. Tokens encrypted, stored in OAuthToken table
  ensureTokenFresh(): checks expiresAt - 60s before every call.
  On refresh failure: invalidate, emit "reconnect" to admin.
  <b>Same API format as OpenAI</b> — only auth header differs.
  Required scope: model.request
end note

class "AnthropicProvider" as PClaude {
  + name = 'anthropic'
  + baseURL = 'https://api.anthropic.com/v1'
  + supportedModels = ['claude-opus-4-6',\n'claude-sonnet-4-6', 'claude-haiku-4-5']
  + contextLimits = { 'claude-opus-4-6': 200000, ... }
  ..
  + countTokens(messages): Promise<number>
  + addCacheBreakpoints(messages): LLMMessage[]
  - parseAnthropicStream(stream): AsyncGenerator<LLMStreamChunk>
  - normalizeToolFormat(tools): AnthropicTool[]
}

note bottom of PClaude
  <b>Unique: exact token counting via API</b>
  POST /v1/messages/count_tokens (not tiktoken).
  Result cached in Redis 60s (hash of messages as key).
  <b>Prompt caching:</b>
  addCacheBreakpoints() inserts cache_control after
  last static turn (system + memory + summary).
  Tracks cache_read_input_tokens vs
  cache_creation_input_tokens per response.
  Both stored in Message.metadata for analytics.
  Required headers: x-api-key, anthropic-version.
end note

class "KimiProvider" as PKimi {
  + name = 'kimi'
  + baseURL = 'https://api.moonshot.cn/v1'
  + supportedModels = ['kimi-k2-5',\n'moonshot-v1-8k',\n'moonshot-v1-32k',\n'moonshot-v1-128k']
  + contextLimits = { 'kimi-k2-5': 131072, ... }
}

note bottom of PKimi
  <b>Extends OpenAIProvider — fully OpenAI-compatible API.</b>
  Only overrides: name, baseURL, supportedModels, contextLimits.
  Token counting: tiktoken (approximate — no counting endpoint).
  Default context 128K — Kimi K2.5 handles long context natively.
end note

class "OpenRouterProvider" as POR {
  + name = 'openrouter'
  + baseURL = 'https://openrouter.ai/api/v1'
  - modelListCacheKey = 'openrouter:models'
  ..
  + discoverModels(): Promise<ModelInfo[]>
  + getContextLimit(modelId): number
  # buildHeaders(): Record<string, string>
}

note bottom of POR
  <b>Extends OpenAIProvider — OpenAI-compatible.</b>
  Required extra headers:
    HTTP-Referer: https://nextgenchat.local
    X-Title: NextGenChat
  Model format: "provider/model-name"
  (e.g. "google/gemini-2.5-pro")
  discoverModels(): GET /api/v1/models, cached 1h in Redis.
  Context limit read from model list per-model.
  usage.cost in response → stored in Message.metadata.
end note

' ── Registry ───────────────────────────────────────────────────

class "ProviderRegistry" as Reg {
  - {static} instance: ProviderRegistry
  - cache: Map<string, IProvider>
  ..
  + {static} getInstance(): ProviderRegistry
  + get(agentId: string): Promise<IProvider>
  + test(agentId: string): Promise<TestResult>
  - loadConfig(agentId): Promise<ProviderConfig>
  - decrypt(ciphertext: string): string
  - build(config: ProviderConfig): IProvider
}

note right of Reg
  <b>Singleton. get(agentId) flow:</b>
  1. Load ProviderConfig from DB (LRU 5min cache)
  2. Decrypt credentials using ENCRYPTION_KEY env var
     (AES-256-GCM, unique IV per record)
  3. Build provider instance if not in instance cache
     (keyed by SHA-256 hash of config)
  4. Return IProvider — caller is unaware of concrete type
  test() fires a minimal 1-token completion to verify creds work.
  Returns { success, model, latencyMs } or { success, error }.
end note

' ── DB Table ───────────────────────────────────────────────────

class "ProviderConfig\n(DB Table)" as DBConfig {
  + id: uuid
  + agentId: uuid
  + providerName: ProviderName
  + model: string
  + credentials: string  <<AES-256-GCM encrypted JSONB>>
  + config: JSONB  <<temperature, maxTokens, etc.>>
  + createdAt: timestamp
  + updatedAt: timestamp
}

class "OAuthToken\n(DB Table)" as DBOAuth {
  + id: uuid
  + agentId: uuid
  + accessToken: string  <<AES-256-GCM encrypted>>
  + refreshToken: string  <<AES-256-GCM encrypted>>
  + expiresAt: timestamp
  + scope: string
  + createdAt: timestamp
  + updatedAt: timestamp
}

' ── Relationships ───────────────────────────────────────────────

IProvider <|.. Base
Base <|-- POai
POai <|-- POauthCodex : extends\n(OAuth auth)
POai <|-- PKimi : extends\n(OpenAI-compat)
POai <|-- POR : extends\n(OpenAI-compat)
Base <|-- PClaude

Reg ..> IProvider : returns
Reg ..> DBConfig : reads
POauthCodex ..> DBOAuth : reads/writes

IProvider ..> TOpts : consumes
IProvider ..> TResp : produces
IProvider ..> TChunk : yields (stream)

@enduml


