title <b>NextGenChat — System Architecture Overview</b>\n<size:10>One backend, multiple clients. Security posture controlled by DEPLOYMENT_MODE env var.</size>

' ────────────────────────────────────────────────
' CLIENTS
' ────────────────────────────────────────────────
package "Clients" #EAF8EA {
  component "**Next.js 15**\nWeb App\n(App Router + TS)" as WebApp #C8EEC8
  component "**React Native**\n+ Expo (Phase 8)\nMobile App" as Mobile #C8EEC8
  component "**External**\nAPI Integrations\n(Future)" as ExtClient #C8EEC8
}

note as NMobile
  <b>Mobile additions (Phase 8):</b>
  • Expo SecureStore — never AsyncStorage
  • Certificate pinning — MITM prevention
  • Biometric auth — local, never sent to server
  • Push notifications — FCM + APNs
  • Device-bound refresh tokens (30-day)
  • Remote revoke: DELETE /sessions/:deviceId
end note
Mobile .. NMobile

' ────────────────────────────────────────────────
' GATEWAY
' ────────────────────────────────────────────────
package "Gateway" #EBEBF8 {
  component "**Caddy / Nginx**\nReverse Proxy\nTLS Termination\nWebSocket Upgrade" as GW #C8C8EE
}

note as NGW
  <b>LOCAL mode:</b> HTTP, localhost only, no TLS
  <b>SHARED mode:</b>
  • Auto-TLS via Let's Encrypt
  • HSTS: max-age=31536000; includeSubDomains; preload
  • CORS: explicit domain allowlist (no wildcard)
  • WebSocket upgrade proxied to Socket.io
end note
GW .. NGW

' ────────────────────────────────────────────────
' BACKEND
' ────────────────────────────────────────────────
package "Backend  •  Node.js 22 + TypeScript 5  •  Fastify" #FFFCF0 {

  package "API & Real-time Layer" #F5F5F5 {
    component "**Fastify**\nREST API\n(routes, middleware,\npreHandler hooks)" as Fastify #FFF3C8
    component "**Socket.io 4**\n/chat  +  /presence\nrooms: channel:{id}" as SIO #FFF3C8
  }

  note as NSIO
    <b>Namespaces:</b>
    /chat  — messages, edits, reactions, streaming
    /presence — online / away / offline status
    <b>Rooms:</b> channel:{channelId}
    Uses @socket.io/redis-adapter.
    Every broadcast goes through Redis pub/sub —
    works with 1 instance, scales to N instances.
  end note
  SIO .. NSIO

  package "Feature Modules  (src/modules/)" #F5F5F5 {
    component "**Auth**\nJWT · Argon2id\nRBAC · Setup Wizard" as M_Auth
    component "**Chat**\nMessages · Channels\nReactions · Attachments\nFull-text search" as M_Chat
    component "**Agents**\nTriggers · Memory\nCron · Tool approval" as M_Agent
    component "**Rules Engine**\nPolicy evaluation\nApproval workflow\nAudit log" as M_Rules
    component "**MCP Manager**\nSubprocess lifecycle\nTool discovery\nHealth monitoring" as M_MCP
    component "**Workspace**\nFiles · Versioning\nDoc files (Agent.md\nidentity.md etc.)" as M_WS
  }

  ' LLM Provider Layer
  package "LLM Provider Layer  (src/modules/providers/)" #FFF0EF {
    component "**Provider Registry**\n[singleton]\nDecrypts credentials\nCaches instances" as PReg #FFD0CE

    component "OpenAI\nProvider\ngpt-4o · o1 · o3" as P_OAI #FFBCBA
    component "Codex OAuth\nProvider\n(OAuth 2.0 flow)" as P_Codex #FFBCBA
    component "Anthropic\nProvider\nclaude-opus/sonnet/haiku" as P_Claude #FFBCBA
    component "Kimi K2.5\nProvider\n(moonshot.cn)" as P_Kimi #FFBCBA
    component "OpenRouter\nProvider\n(any model)" as P_OR #FFBCBA

    PReg --> P_OAI
    PReg --> P_Codex
    PReg --> P_Claude
    PReg --> P_Kimi
    PReg --> P_OR
  }

  note as NReg
    <b>All 5 implement LLMProvider interface:</b>
    complete() · stream() · countTokens()
    Credentials: AES-256-GCM encrypted in DB.
    Never returned to any client via any endpoint.
    Decrypted in memory only during LLM calls.
    Kimi + OpenRouter extend OpenAIProvider
    (OpenAI-compatible APIs, different baseURL only).
    Codex OAuth: tokens auto-refreshed before expiry.
  end note
  PReg .. NReg

  ' Context Window Management
  package "Context Window Management  (src/modules/context/)" #F0F0FF {
    component "**Context Builder**\nAssembles prompt\nwithin token budget" as CB #C8C8FF
    component "**Token Counter**\ntiktoken (OAI·Kimi·OR)\nAnthropic API (exact)" as TC #C8C8FF
    component "**Compaction Svc**\nSummarize old msgs\nasync — never blocks" as CS #C8C8FF
    component "**Cache Service**\ncache_control hints\n(Anthropic prompt caching)" as CacheSvc #C8C8FF

    CB --> TC
    CB --> CacheSvc
    CB ..> CS : if over budget\n(async job)
  }

  note as NCB
    <b>Context build order (within token budget):</b>
    1. System prompt       ← marked cacheable (Anthropic)
    2. Agent memory        ← marked cacheable
    3. ConversationSummary ← if compaction exists
    4. Recent messages     ← fill remaining budget
    5. Trigger message     ← always last
    Reserve RESPONSE_BUFFER = 4096 tokens always.
  end note
  CB .. NCB

  ' Async Workers
  package "Async Workers  (BullMQ)" #F0FFF4 {
    component "**Agent Processor**\nLLM call + streaming\nMemory update\ntimeout: 90s" as W_Agent #A8DDB0
    component "**Compaction Worker**\nSummarize old context\nStore ConversationSummary" as W_Compact #A8DDB0
    component "**File Scanner**\nClamAV virus scan\non attachment upload" as W_File #A8DDB0
    component "**Cron Worker**\nAgent heartbeat\nwake-up jobs" as W_Cron #A8DDB0
  }

  note as NWorker
    <b>ALL LLM calls happen in workers — NEVER in the HTTP cycle.</b>
    Worker streams chunks back via Socket.io in real time.
    On timeout (90s) or error: emit error message to channel.
    Retry: max 2x, exponential backoff.
    Cron jobs managed as BullMQ repeatable jobs.
  end note
  W_Agent .. NWorker

}

' ────────────────────────────────────────────────
' STORAGE
' ────────────────────────────────────────────────
package "Storage" #F4F0FF {
  database "**PostgreSQL 16**\nPrimary Database" as PG #DDD0FF
  database "**Redis 7**\nCache · PubSub\nQueue · RateLimit" as Redis #DDD0FF
  database "**MinIO / S3**\nFile Storage\n(workspaces + attachments)" as S3 #DDD0FF
}

note as NPG
  <b>Key tables:</b>
  User, RefreshToken, Workspace, Channel
  Message (content + <b>metadata JSONB</b>)
  Agent, AgentMemory, AgentToolCall
  <b>ConversationSummary</b> (compaction results)
  <b>ProviderConfig</b> (credentials encrypted)
  <b>OAuthToken</b> (Codex OAuth tokens)
  Rule, RuleViolation
  AuditLog (append-only, HMAC-signed)
end note
PG .. NPG

note as NRedis
  <b>Redis responsibilities:</b>
  • Socket.io pub/sub (multi-instance broadcast)
  • BullMQ queue backend (all job queues)
  • Rate-limit counters (per IP + per user)
  • Presence: SET user:{id}:status EX 60
  • Token count cache: 60s TTL
  • OpenRouter model list: 1h TTL
  • Session blacklist (revoked tokens)
end note
Redis .. NRedis

' ────────────────────────────────────────────────
' EXTERNAL
' ────────────────────────────────────────────────
package "External LLM APIs" #FFF5F5 {
  component "OpenAI\napi.openai.com/v1" as E_OAI #FFCCCC
  component "Anthropic\napi.anthropic.com/v1" as E_Claude #FFCCCC
  component "Moonshot\napi.moonshot.cn/v1\n(Kimi K2.5)" as E_Kimi #FFCCCC
