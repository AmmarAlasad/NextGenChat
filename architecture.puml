skinparam classBackgroundColor #FAFAFA
skinparam classBorderColor #888888
skinparam packageBackgroundColor #F5F5F5

package "Identity & Access" {
  class User {
    id : String (cuid)
    username : String (unique)
    passwordHash : String (Argon2id)
    createdAt : DateTime
  }
  class WorkspaceMembership {
    userId : String
    workspaceId : String
    role : String
    joinedAt : DateTime
  }
  class OAuthToken {
    userId : String
    provider : String
    accessToken : String (encrypted)
    refreshToken : String (encrypted)
    expiresAt : DateTime
  }
}

package "Workspace & Conversation" {
  class Workspace {
    id : String (cuid)
    name : String
    slug : String (unique)
    createdAt : DateTime
  }
  class Project {
    id : String (cuid)
    workspaceId : String
    name : String
    description : String?
  }
  class Channel {
    id : String (cuid)
    workspaceId : String
    projectId : String?
    name : String
    type : ChannelType
    note: PUBLIC | PRIVATE | DIRECT
  }
  class Message {
    id : String (cuid)
    channelId : String
    senderId : String?
    senderType : SenderType
    note: USER | AGENT
    content : String
    isRelay : Boolean
    metadata : JSON?
    createdAt : DateTime
  }
  class ConversationSummary {
    id : String (cuid)
    channelId : String
    agentId : String
    summary : String
    tokenCount : Int
    fromMessageId : String
    toMessageId : String
    createdAt : DateTime
  }
}

package "Agent Model" {
  class Agent {
    id : String (cuid)
    workspaceId : String
    name : String
    slug : String (unique)
    status : AgentStatus
    note: ACTIVE | DISABLED
    triggerMode : TriggerMode
    note: ALL_MESSAGES | MENTIONS_ONLY | AUTO
    primaryChannelId : String?
    createdAt : DateTime
  }
  class AgentMembership {
    agentId : String
    channelId : String
    joinedAt : DateTime
  }
  class AgentIdentity {
    agentId : String (1:1)
    persona : String?
    voiceTone : String?
    systemPrompt : String?
  }
  class AgentMemory {
    id : String (cuid)
    agentId : String
    scope : String
    key : String
    value : String
    updatedAt : DateTime
  }
  class AgentSkill {
    id : String (cuid)
    agentId : String
    name : String
    type : SkillType
    toolNames : String[]
    rootPath : String
    enabled : Boolean
  }
  class ProviderConfig {
    id : String (cuid)
    agentId : String
    providerName : String
    model : String
    encryptedApiKey : String (AES-256-GCM)
    isDefault : Boolean
  }
}

package "Agent Workspace Files" {
  class WorkspaceFile {
    id : String (cuid)
    agentId : String?
    workspaceId : String?
    docType : String
    note: soul | identity | agent | user |\nmemory | heartbeat | pickup | project | agency
    fileName : String
    content : String
    version : Int
    updatedAt : DateTime
  }
}

package "MCP Integration" {
  class McpServerTool {
    id : String (cuid)
    agentId : String
    serverName : String
    toolName : String
    description : String
    inputSchema : JSON
    enabled : Boolean
