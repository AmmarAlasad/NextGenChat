@startuml MessagePipeline
title <b>NextGenChat — Agent Message Pipeline</b>\n<size:11>End-to-end path from user message to streamed reply (Phases 1–5)</size>

skinparam defaultFontName Helvetica
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor User
participant "Web UI\n(Next.js)" as Web
participant "Socket.io\n/chat" as SIO
participant "Chat Service" as ChatSvc
database "SQLite" as DB
participant "Agent Routing\n(3-stage filter)" as Routing
participant "Pickup LLM\n(gpt-4o-mini · temp=0)" as Pickup
queue "BullMQ\nAgent Queue" as Queue
participant "Agent Processor\n(thin shell)" as AProc
participant "SessionLane\nRegistry" as Lanes
participant "AgentSession\nGateway" as Gateway
participant "Context\nBuilder" as CB
participant "Agent Visibility\nFilter" as Visibility
participant "LLM Provider\n(OpenAI · Anthropic · Kimi\nOpenRouter · Codex)" as LLM
participant "Tool Registry\n(bash · read/write\nsend_reply · relay)" as Tools
participant "Agent Output\nSanitizer" as Sanitize

User -> Web : type + send message
Web -> SIO : emit message:send
SIO -> ChatSvc : validate (Zod) + persist
ChatSvc -> DB : INSERT Message (senderType=USER)
ChatSvc --> SIO : emit message:new (broadcast to room)
SIO --> Web : display user message immediately

ChatSvc -> Routing : triggerAgentsForMessage(channelId, messageId)

group Stage 1 — Mode Gate
  Routing -> Routing : skip DISABLED agents
  note right : ALWAYS → respond\nMENTIONS_ONLY → only if @mentioned\nAUTO → continue to Stage 2
end

group Stage 2 — Agent-Sender Guard
  Routing -> Routing : if sender is agent AND isRelay=false\n→ only explicitly mentioned agents proceed
  note right : Prevents infinite agent chains.\nRelay messages (isRelay=true) bypass this.
end

group Stage 3 — Pickup LLM Vote (AUTO mode only)
  Routing -> Pickup : per-agent parallel vote\n[pickup.md as system prompt\n+ named transcript\n+ "has agent replied recently?" flag]
  Pickup --> Routing : YES / NO (default=NO)
  note right : maxTokens=80 · temp=0.0\nFallback on error: silence (NO)
end

Routing -> Queue : enqueue job(s) for responding agents

Queue -> AProc : process(agentId, channelId, messageId)
AProc -> Lanes : acquireLane(agentId:channelId)
note right of Lanes : Serial execution per agent:channel pair.\nPrevents concurrent context corruption.

Lanes -> Gateway : runAgentTurn(agentId, channelId, messageId)

Gateway -> CB : build(agentId, channelId, messageId)
CB -> DB : load workspace files (soul→pickup)
CB -> DB : load project.md (if applicable)
CB -> DB : load ConversationSummary
CB -> DB : load recent messages
CB -> Visibility : filter messages by agent visibility rules
note right of Visibility : Agent sees own replies always.\nOther agents' replies only if @mentioned.
CB -> CB : count tokens (tiktoken / Anthropic API)
CB -> CB : reserve RESPONSE_BUFFER (4096 tokens)
alt history exceeds budget
  CB -> DB : schedule compaction job
  CB -> CB : drop oldest turns until fit
end
CB --> Gateway : final prompt payload + tool definitions

Gateway -> LLM : stream(messages, tools, model)
note right of LLM : Provider selected per agent ProviderConfig.\nCredentials decrypted AES-256-GCM.

loop streaming chunks
  LLM --> Gateway : delta chunk
  Gateway -> SIO : emit message:stream:chunk
  SIO --> Web : render live typing
end

alt tool call requested
  LLM --> Gateway : tool_call (name, args)
  Gateway -> Tools : executeToolCall(name, args, agentId, channelId)

  alt send_reply (mid-turn message)
    Tools -> DB : INSERT Message (interim)
    Tools -> SIO : emit message:new
    SIO --> Web : display intermediate message
  end

  alt channel_send_message (cross-channel relay)
    Tools -> DB : INSERT Message (isRelay=true)
    Tools -> Routing : triggerAgentsForMessage (target channel)
  end

  Tools --> Gateway : tool_result
  Gateway -> LLM : stream(messages + tool_result, tools)
  loop streaming chunks
    LLM --> Gateway : delta chunk
    Gateway -> SIO : emit message:stream:chunk
    SIO --> Web : render live typing
  end
end

LLM --> Gateway : final response + usage metadata

Gateway -> Sanitize : stripMessageWrapper(content)
note right of Sanitize : Strips <message speaker="..."> XML wrappers.\nRemoves <thinking>, <scratchpad>, prompt leaks.\nIf output == [[NO_REPLY]] → discard silently.

alt sanitized output is [[NO_REPLY]]
  Gateway -> Gateway : discard — no DB insert, no socket event
else normal response
  Gateway -> DB : INSERT Message (senderType=AGENT, metadata=usage)
  Gateway -> SIO : emit message:stream:end
  Gateway -> SIO : emit message:new
  SIO --> Web : finalize message display
  Gateway -> SIO : emit message:routing:complete
  note right : Sent even when 0 agents responded.\nFrontend exits routing/queued state.
end

@enduml


@startuml AgentRouting
title <b>NextGenChat — Agent Routing (Three-Stage Filter)</b>\n<size:11>Pre-LLM decision: which agents respond to a given message</size>
skinparam defaultFontName Helvetica
skinparam ActivityBackgroundColor #FAFAFA
skinparam ActivityBorderColor #888888

start

:Receive triggerAgentsForMessage(channelId, messageId);
:Load all channel member agents;

partition "Stage 1 — Mode Gate" {
  if (agent.status == DISABLED?) then (yes)
    :Skip — DISABLED;
    stop
  elseif (triggerMode == MENTIONS_ONLY\nAND message does NOT mention agent?) then (yes)
    :Skip — not mentioned;
    stop
  else (pass)
    :Continue;
  endif
}

partition "Stage 2 — Agent-Sender Guard" {
  if (sender is AGENT\nAND isRelay == false\nAND agent not explicitly @mentioned?) then (yes)
    :Skip — agent-to-agent chain suppressed;
    note right
      Relay messages (isRelay=true) bypass
      this guard entirely and proceed to
      Stage 3 as normal.
    end note
    stop
  else (pass or relay)
    :Continue;
  endif
}

partition "Stage 3 — Pickup LLM Vote (AUTO mode)" {
  if (triggerMode == ALL_MESSAGES\nOR triggerMode == MENTIONS_ONLY with match?) then (yes)
    :Respond — mode explicitly allows it;
  else (AUTO mode)
    :Call gpt-4o-mini pickup vote;
    note right
      System prompt = agent's pickup.md
      User content  = last 5 messages (named transcript)
      maxTokens=80 · temperature=0.0
      Includes "has agent replied recently?" flag
      Default answer = NO
    end note
    if (pickup returns YES?) then (yes)
      :Respond;
    else (NO or error)
      :Skip — pickup said no;
      stop
    endif
  endif
}

:Enqueue BullMQ job (agent:process);
:AgentSessionGateway.runAgentTurn();
stop

@enduml


@startuml ContextAssembly
title <b>NextGenChat — Context Assembly</b>\n<size:11>Token budget management · 12-step injection · compaction · prefix caching</size>
skinparam defaultFontName Helvetica
skinparam ActivityBackgroundColor #FAFAFA

start

:ContextBuilder.build(agentId, channelId, messageId);
:Resolve ProviderConfig → model token limit;
:Reserve RESPONSE_BUFFER (default 4096 tokens);
:Compute available budget = limit − buffer;

group "Static Context (cached)" {
  :Ensure all seven agent files exist (create defaults if missing);

  :1. runtime-context.md — channel, participants, constraints;
  :2. soul.md — ethics first, overrides everything;
  :3. identity.md — persona and voice;
  :4. Agent.md — operating manual;
  :5. tools.md — generated approved tool list (not a file);
  :6. user.md — agent's model of the user;
  :7. memory.md — long-term learnings;
  :8. Heartbeat.md — resumable work state;
  :9. project.md — if channel belongs to a project;
  :10. agency.md — workspace-level constitution;
  :Compute static prefix hash;
  if (hash matches cache AND not expired (5 min TTL)?) then (yes)
    :Load static prefix from Redis cache;
  else (no)
    :Build static prefix from files;
    :Store in Redis with TTL;
    note right
      Anthropic: inject cache_control: { type: "ephemeral" }
      after static block to enable prompt caching.
      Track cache_read vs cache_creation tokens in metadata.
    end note
  endif
}

group "Dynamic Context" {
  :11. Load latest ConversationSummary (compacted history);
  :12. Cross-channel context (DM-only: other DM channels with same user);
  :Load recent channel messages;
  :Apply AgentVisibilityFilter;
  note right
    Agent sees own replies always.
    Other agents' replies only if reply @mentions this agent
    (by @slug or name). Prevents agents from seeing
    unrelated parallel conversation threads.
  end note
}

:Token count current total (tiktoken or Anthropic count API);

if (Within budget (with 1.2× safety margin)?) then (yes)
  :Include all recent messages;
else (no)
  :Drop oldest turns until within budget;
  if (No ConversationSummary exists yet?) then (yes)
    :Schedule async compaction job on CQueue;
    note right
      Compaction does NOT block current reply.
      It summarises overflow history for the next turn.
    end note
  endif
endif

:Append trigger message last (highest priority);
:Inject tool definitions (bash · read · write · send_reply · relay);
:Return assembled prompt payload to AgentSessionGateway;
stop

@enduml


@startuml DomainModel
title <b>NextGenChat — Domain Model</b>\n<size:11>All persisted entities · Prisma / SQLite</size>
