{
  "name": "nextgenchat",
  "version": "0.1.0",
  "description": "Local-first collaborative AI agent workspace platform",
  "bin": {
    "nextgenchat": "./bin/nextgenchat.js",
    "ngc": "./bin/nextgenchat.js"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "setup:local": "bash scripts/setup.sh",
    "setup:local:win": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "install:local": "bash scripts/install.sh",
    "install:local:win": "powershell -ExecutionPolicy Bypass -File scripts/install.ps1",
    "service:install": "bash scripts/service-install.sh",
    "service:install:win": "powershell -ExecutionPolicy Bypass -File scripts/service-install.ps1",
    "service:run": "bash scripts/service-run.sh",
    "service:run:win": "powershell -ExecutionPolicy Bypass -File scripts/service-run.ps1",
    "service:status": "systemctl --user status nextgenchat.service",
    "service:logs": "journalctl --user -u nextgenchat.service -f",
    "service:stop": "systemctl --user stop nextgenchat.service",
    "service:disable": "bash scripts/service-disable.sh disable",
    "service:remove": "bash scripts/service-disable.sh remove",
    "service:stop:win": "powershell -ExecutionPolicy Bypass -File scripts/service-disable.ps1 stop",
    "service:disable:win": "powershell -ExecutionPolicy Bypass -File scripts/service-disable.ps1 disable",
    "service:remove:win": "powershell -ExecutionPolicy Bypass -File scripts/service-disable.ps1 remove",
    "dev:local": "bash scripts/dev.sh",
    "dev:local:win": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "dev:phase1": "pnpm dev:local",
    "stop": "bash scripts/stop.sh",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "keywords": [
    "ai",
    "agents",
    "chat",
    "local-first",
    "mcp",
    "nextjs",
    "fastify",
    "workspace",
    "automation"
  ],
  "author": "Ammar Alasad",
  "license": "MIT",
  "homepage": "https://github.com/AmmarAlasad/NextGenChat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmmarAlasad/NextGenChat.git"
  },
  "bugs": {
    "url": "https://github.com/AmmarAlasad/NextGenChat/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.43.0"
  }
}
