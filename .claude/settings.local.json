{
  "permissions": {
    "allow": [
      "Bash(pnpm --filter @nextgenchat/web typecheck)",
      "Bash(pnpm --filter @nextgenchat/web exec tsc --noEmit)",
      "mcp__Claude_Preview__preview_start",
      "Bash(pnpm --filter @nextgenchat/web dev)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(taskkill /PID 16116 /F)",
      "Bash(cmd /c \"taskkill /PID 16116 /F\")",
      "Bash(cmd /c \"netstat -ano | findstr :3000\")",
      "Bash(cmd /c \"netstat -ano | findstr LISTEN | findstr :3000\")",
      "Bash(cmd /c \"netstat -ano\")",
      "Bash(powershell -Command \"Stop-Process -Id 16116 -Force -ErrorAction SilentlyContinue; Start-Sleep -Seconds 1; Get-NetTCPConnection -LocalPort 3000 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess\")",
      "Bash(powershell -Command \"Stop-Process -Id 16116 -Force\")",
      "Bash(powershell -Command \"Get-Process -Id 16116 -ErrorAction SilentlyContinue\")",
      "Bash(powershell -Command \"Get-NetTCPConnection -LocalPort 3000 -ErrorAction SilentlyContinue | Select-Object LocalPort, OwningProcess\")",
      "Bash(pnpm --filter @nextgenchat/web add react-markdown remark-gfm)",
      "Bash(pnpm --filter @nextgenchat/types build)",
      "Bash(pnpm --filter @nextgenchat/backend exec tsc --noEmit)",
      "Bash(npx tsc:*)"
    ]
  }
}
