# Runtime
NODE_ENV=development
DEPLOYMENT_MODE=local

# App URLs
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Backend
PORT=3001
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
ENCRYPTION_KEY=replace-with-32-byte-base64-or-hex-key

# Local packaged mode
DATABASE_URL=file:./dev.db
REDIS_ENABLED=false
REDIS_URL=

# Agent workspaces
# Recommended: keep this outside the repo so reinstalling or updating the codebase
# does not affect durable agent files.
AGENT_WORKSPACES_DIR=/home/your-user/.nextgenchat/agent-workspaces

# MinIO / S3-compatible storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=nextgenchat

# Optional provider-specific metadata
OPENROUTER_HTTP_REFERER=https://nextgenchat.local
OPENROUTER_X_TITLE=NextGenChat

# Local provider setup
OPENAI_API_KEY=disabled-local-key
OPENAI_MODEL=gpt-4o-mini
AGENT_MAX_TOOL_ROUNDS=24
