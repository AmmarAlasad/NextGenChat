# Runtime
NODE_ENV=development
DEPLOYMENT_MODE=local

# App URLs
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Backend
PORT=3001
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
ENCRYPTION_KEY=replace-with-32-byte-base64-or-hex-key

# Data stores
# TCP (password auth) — set postgres password first via: ALTER USER postgres WITH PASSWORD '...'
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nextgenchat?schema=public
# Socket (peer auth, no password) — create OS-matching role first: CREATE USER <yourusername> WITH SUPERUSER;
# DATABASE_URL=postgresql://<yourusername>@/nextgenchat?host=/var/run/postgresql&schema=public
REDIS_URL=redis://localhost:6379

# MinIO / S3-compatible storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=nextgenchat

# Optional provider-specific metadata
OPENROUTER_HTTP_REFERER=https://nextgenchat.local
OPENROUTER_X_TITLE=NextGenChat

# Phase 1 local provider setup
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
